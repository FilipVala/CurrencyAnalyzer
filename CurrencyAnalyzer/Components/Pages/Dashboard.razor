@page "/dashboard"
@rendermode InteractiveServer

@using MudBlazor
@using CurrencyAnalyzer.Core.Interfaces
@using CurrencyAnalyzer.Core.Models

@inject IAnalyticsService AnalyticsService
@inject IUserSettingsService UserSettingsService
@inject NavigationManager Navigation
@inject IAuthService AuthService

<PageTitle>Dashboard</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">

    <h1 class="mb-0">Currency Dashboard</h1>

    <button class="btn btn-outline-danger"
            @onclick="Logout">
        Logout
    </button>

</div>

@if (isLoading)
{
    <div class="alert alert-info">
        Loading analysis...
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}
else if (analysisResult != null)
{
    <div class="row mb-4">

        <div class="col-md-4">
            <div class="card text-bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Strongest Currency</h5>

                    <p class="card-text fs-4">
                        @analysisResult.Strongest.Currency
                    </p>

                    <p>
                        Rate: @analysisResult.Strongest.Rate
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-bg-danger mb-3">
                <div class="card-body">
                    <h5 class="card-title">Weakest Currency</h5>

                    <p class="card-text fs-4">
                        @analysisResult.Weakest.Currency
                    </p>

                    <p>
                        Rate: @analysisResult.Weakest.Rate
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Average Rate</h5>

                    <p class="card-text fs-4">
                        @analysisResult.AverageRate
                    </p>

                    <p>
                        Base: @analysisResult.BaseCurrency
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="card">

        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Exchange Rates</h4>

            <button class="btn btn-primary"
                    @onclick="ReloadDashboard">
                🔄 Refresh
            </button>
        </div>

        <div class="card-body">

            <p>
                <strong>Calculated:</strong>
                @analysisResult.CalculatedAt.ToLocalTime()
            </p>

            <table class="table table-striped table-hover">

                <thead class="table-dark">
                    <tr>
                        <th>Currency</th>
                        <th>Rate</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var rate in analysisResult.Rates)
                    {
                        <tr>
                            <td>@rate.Key</td>
                            <td>@rate.Value</td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div class="card mt-4">

        <div class="card-header">
            <h4 class="mb-0">Exchange Rate Chart</h4>
        </div>

        <div class="card-body">

            <MudChart T="double"
                      ChartType="ChartType.Bar"
                      ChartSeries="@chartSeries"
                      XAxisLabels="xAxisLabels"
                      Width="100%"
                      Height="400px" />

        </div>

    </div>
}

@code {

    private AnalysisResult? analysisResult;

    private bool isLoading = true;

    private string? errorMessage;

    private string[] xAxisLabels = Array.Empty<string>();

    private List<ChartSeries<double>> chartSeries = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            isLoading = true;

            errorMessage = null;

            var settings = await UserSettingsService.GetSettingsAsync();

            analysisResult = await AnalyticsService.PerformFullAnalysisAsync(
                settings.BaseCurrency,
                settings.SelectedCurrencies);

            GenerateChart();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GenerateChart()
    {
        if (analysisResult == null || !analysisResult.Rates.Any())
            return;

        xAxisLabels = analysisResult.Rates.Keys.ToArray();

        chartSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = "Exchange Rates",
                Data = analysisResult.Rates.Values
                    .Select(r => (double)r)
                    .ToList()
            }
        };
    }

    private async Task ReloadDashboard()
    {
        isLoading = true;

        analysisResult = null;

        StateHasChanged();

        await Task.Delay(100);

        await LoadDashboardAsync();

        StateHasChanged();
    }

    private void Logout()
    {
        AuthService.Logout();

        Navigation.NavigateTo("/login", forceLoad: true);
    }
}

