@page "/"
@using CurrencyAnalyzer.Core.Interfaces
@using CurrencyAnalyzer.Core.Models

@inject IAuthService AuthService
@inject IUserSettingsService SettingsService
@inject IAnalyticsService AnalyticsService
@inject NavigationManager Navigation

<h1>Měnový Analyzátor</h1>

<p><strong>Přihlášený uživatel:</strong> @AuthService.GetCurrentUsername()</p>

<hr />

<button @onclick="LoadRates" class="btn btn-success">Načíst aktuální kurzy</button>
<button @onclick="Logout" class="btn btn-danger">Odhlásit se</button>

<p>@message</p>

@code {
    private string message = "Klikni na tlačítko pro načtení kurzů...";

    private async Task LoadRates()
    {
        try
        {
            var settings = await SettingsService.GetSettingsAsync();
            var result = await AnalyticsService.PerformFullAnalysisAsync(
                settings.BaseCurrency, settings.SelectedCurrencies);

            message = $"✅ Nejsilnější: {result.Strongest.Currency} | Nejslabší: {result.Weakest.Currency} | Průměr: {result.AverageRate}";
        }
        catch (Exception ex)
        {
            message = $"❌ Chyba: {ex.Message}";
        }
    }

    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/login", true);
    }
}