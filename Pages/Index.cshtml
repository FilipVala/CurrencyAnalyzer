@page "/"
@using CurrencyAnalyzer.Core.Interfaces
@using CurrencyAnalyzer.Core.Models
@using Microsoft.AspNetCore.Components

@inject IAuthService AuthService
@inject IUserSettingsService SettingsService
@inject IAnalyticsService AnalyticsService
@inject NavigationManager Navigation

<h1>Měnový Analyzátor</h1>

<p><strong>Přihlášený:</strong> @AuthService.GetCurrentUsername()</p>

<button onclick="@LoadRates">Načíst kurzy</button>
<button onclick="@Logout">Odhlásit se</button>

@functions {
    private async Task LoadRates()
    {
        try
        {
            var settings = await SettingsService.GetSettingsAsync();
            var result = await AnalyticsService.PerformFullAnalysisAsync(
                settings.BaseCurrency, settings.SelectedCurrencies);

            Console.WriteLine($"Nejsilnější: {result.Strongest.Currency}");
            Console.WriteLine($"Nejslabší: {result.Weakest.Currency}");
        }
        catch (Exception ex)
        {
            Console.WriteLine("Chyba: " + ex.Message);
        }
    }

    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/login", true);
    }
}