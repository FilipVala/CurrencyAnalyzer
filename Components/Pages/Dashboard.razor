@page "/dashboard"
@rendermode InteractiveServer

@using CurrencyAnalyzer.Core.Interfaces
@using CurrencyAnalyzer.Core.Models


@inject IAnalyticsService AnalyticsService
@inject IUserSettingsService UserSettingsService
@inject NavigationManager Navigation


<PageTitle>Dashboard</PageTitle>

<h1 class="mb-4">Currency Dashboard</h1>

@if (isLoading)
{
    <div class="alert alert-info">
        Loading analysis...
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}
else if (analysisResult != null)
{
    <div class="row mb-4">

        <div class="col-md-4">
            <div class="card text-bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Strongest Currency</h5>

                    <p class="card-text fs-4">
                        @analysisResult.Strongest.Currency
                    </p>

                    <p>
                        Rate: @analysisResult.Strongest.Rate
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-bg-danger mb-3">
                <div class="card-body">
                    <h5 class="card-title">Weakest Currency</h5>

                    <p class="card-text fs-4">
                        @analysisResult.Weakest.Currency
                    </p>

                    <p>
                        Rate: @analysisResult.Weakest.Rate
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Average Rate</h5>

                    <p class="card-text fs-4">
                        @analysisResult.AverageRate
                    </p>

                    <p>
                        Base: @analysisResult.BaseCurrency
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="card">

        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Exchange Rates</h4>

            <button class="btn btn-primary"
                    @onclick="ReloadDashboard">
                🔄 Refresh
            </button>
        </div>

        <div class="card-body">

            <p>
                <strong>Calculated:</strong>
                @analysisResult.CalculatedAt.ToLocalTime()
            </p>

            <table class="table table-striped table-hover">

                <thead class="table-dark">
                    <tr>
                        <th>Currency</th>
                        <th>Rate</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var rate in analysisResult.Rates)
                    {
                        <tr>
                            <td>@rate.Key</td>
                            <td>@rate.Value</td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
}

@code {

    private AnalysisResult? analysisResult;

    private bool isLoading = true;

    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            isLoading = true;

            var settings = await UserSettingsService.GetSettingsAsync();

            analysisResult = await AnalyticsService.PerformFullAnalysisAsync(
                settings.BaseCurrency,
                settings.SelectedCurrencies);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadDashboard()
    {
        isLoading = true;

        analysisResult = null;

        StateHasChanged();

        await Task.Delay(100);

        await LoadDashboardAsync();

        StateHasChanged();
    }
}