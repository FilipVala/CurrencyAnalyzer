@page "/settings"
@rendermode InteractiveServer

@using CurrencyAnalyzer.Core.Models
@using CurrencyAnalyzer.Core.Interfaces

@inject IUserSettingsService UserSettingsService
@inject NavigationManager Navigation

<PageTitle>Nastavení</PageTitle>

<h1>Nastavení</h1>

@if (settings == null)
{
    <p>Načítám...</p>
}
else
{
    <div class="card p-4">

        <div class="mb-4">
            <label class="form-label fw-bold">Základní měna</label>

            <select class="form-select"
                    value="@settings.BaseCurrency"
                    @onchange="OnBaseCurrencyChanged">

                @foreach (var currency in AvailableCurrencies)
                {
                    <option value="@currency">@currency</option>
                }
            </select>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">Sledované měny</label>

            @foreach (var currency in AvailableCurrencies)
            {
                var isBase = currency == settings.BaseCurrency;

                <div class="form-check mb-2">
                    <input class="form-check-input"
                           type="checkbox"
                           checked="@IsSelected(currency)"
                           disabled="@isBase"
                           @onchange="async e => await ToggleCurrency(currency, (bool)e.Value!)" />

                    <label class="form-check-label">@currency</label>
                </div>
            }
        </div>

        <div class="d-flex gap-3">
            <button class="btn btn-primary"
                    disabled="@(!isDirty)"
                    @onclick="SaveSettings">
                💾 Uložit
            </button>

            <button class="btn btn-secondary"
                    @onclick="ResetSettings">
                🔄 Reset
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert alert-info mt-3">
                @StatusMessage
            </div>
        }
    </div>
}

@code {

    private UserSettings? settings;
    private string StatusMessage = "";
    private bool isDirty = false;

    private readonly List<string> AvailableCurrencies =
    [
        "EUR","USD","CZK","GBP","JPY","CHF","PLN"
    ];

    protected override async Task OnInitializedAsync()
    {
        settings = await UserSettingsService.GetSettingsAsync();
    }

    private bool IsSelected(string currency)
        => settings?.SelectedCurrencies.Contains(currency) ?? false;

    private async Task ToggleCurrency(string currency, bool isChecked)
    {
        if (settings == null)
            return;

        if (isChecked)
            settings = await UserSettingsService.AddCurrencyAsync(currency);
        else
            settings = await UserSettingsService.RemoveCurrencyAsync(currency);
    }

    private void OnBaseCurrencyChanged(ChangeEventArgs e)
    {
        settings.BaseCurrency = e.Value?.ToString() ?? "EUR";
        isDirty = true;
    }

    private async Task SaveSettings()
    {
        if (settings == null) return;

        await UserSettingsService.SaveSettingsAsync(settings);

        isDirty = false;
        StatusMessage = "✅ Uloženo";
    }

    private async Task ResetSettings()
    {
        await UserSettingsService.ResetToDefaultAsync();

        settings = await UserSettingsService.GetSettingsAsync();

        isDirty = false;
        StatusMessage = "🔄 Resetováno";
    }
}