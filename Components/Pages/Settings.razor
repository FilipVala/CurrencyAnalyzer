@page "/settings"
@rendermode InteractiveServer

@using CurrencyAnalyzer.Core.Models
@using CurrencyAnalyzer.Core.Interfaces

@inject IUserSettingsService UserSettingsService
@inject NavigationManager Navigation
@inject IAuthService AuthService

<PageTitle>Nastavení</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">

    <h1 class="mb-0">Nastavení</h1>

    <button class="btn btn-outline-danger"
            @onclick="Logout">
        Logout
    </button>

</div>

@if (settings == null)
{
    <p>Načítám...</p>
}
else
{
    <div class="card p-4">

        <div class="mb-4">
            <label class="form-label fw-bold">Základní měna</label>

            <select class="form-select"
                    value="@settings.BaseCurrency"
                    @onchange="OnBaseCurrencyChanged">

                @foreach (var currency in AvailableCurrencies)
                {
                    <option value="@currency">@currency</option>
                }
            </select>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">Sledované měny</label>

            @foreach (var currency in AvailableCurrencies)
            {
                var isBase = currency == settings.BaseCurrency;

                <div class="form-check mb-2">
                    <input class="form-check-input"
                           type="checkbox"
                           checked="@IsSelected(currency)"
                           disabled="@isBase"
                           @onchange="async e => await ToggleCurrency(currency, (bool)e.Value!)" />

                    <label class="form-check-label">@currency</label>
                </div>
            }
        </div>

        <div class="d-flex gap-3">
            

            <button class="btn btn-secondary"
                    @onclick="ResetSettings">
                🔄 Reset
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert alert-info mt-3">
                @StatusMessage
            </div>
        }
    </div>
}

@code {

    private UserSettings? settings;
    private string StatusMessage = "";

    private readonly List<string> AvailableCurrencies =
    [
        "EUR","USD","CZK","GBP","JPY","CHF","PLN"
    ];

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsLoggedIn())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        settings = await UserSettingsService.GetSettingsAsync();
    }

    private bool IsSelected(string currency)
        => settings?.SelectedCurrencies.Contains(currency) ?? false;

    private async Task ToggleCurrency(string currency, bool isChecked)
    {
        if (settings == null)
            return;

        if (isChecked)
            settings = await UserSettingsService.AddCurrencyAsync(currency);
        else
            settings = await UserSettingsService.RemoveCurrencyAsync(currency);

        StatusMessage = "✅ Nastavení uloženo";
    }

    private async Task OnBaseCurrencyChanged(ChangeEventArgs e)
    {
        if (settings == null)
            return;

        var currency = e.Value?.ToString() ?? "EUR";

        settings = await UserSettingsService.SetBaseCurrencyAsync(currency);

        StatusMessage = "✅ Základní měna změněna";
    }

    private async Task ResetSettings()
    {
        await UserSettingsService.ResetToDefaultAsync();

        settings = await UserSettingsService.GetSettingsAsync();

        StatusMessage = "🔄 Resetováno";
    }

    private void Logout()
{
    AuthService.Logout();

    Navigation.NavigateTo("/login", forceLoad: true);
}
}